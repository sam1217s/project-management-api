const { body } = require('express-validator');

const validateState = [
  body('name')
    .trim()
    .isLength({ min: 3, max: 50 })
    .withMessage('Nombre: 3-50 caracteres'),

  body('description')
    .optional()
    .trim()
    .isLength({ max: 200 })
