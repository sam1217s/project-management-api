const { validationResult } = require('express-validator');
const { sendError } = require('../utils/response.util');

const handleValidation = (req, res, next) => {
  const errors = validationResult(req);
  
  if (!errors.isEmpty()) {
    const formattedErrors = errors.array().map(error => ({
      field: error.path || error.param,
      message: error.msg,
      value: error.value,
      location: error.location
    }));

    return sendError(res, 400, 'Errores de validación', formattedErrors);
  }
  
  next();
};

// Middleware para validar ObjectId de MongoDB
const validateObjectId = (paramName = 'id') => {
  return (req, res, next) => {
    const id = req.params[paramName];
    
    if (!id || !id.match(/^[0-9a-fA-F]{24}$/)) {
      return sendError(res, 400, `ID ${paramName} inválido`);
    }
    
    next();
  };
};

// Middleware para validar paginación
const validatePagination = (req, res, next) => {
  const page = parseInt(req.query.page);
  const limit = parseInt(req.query.limit);
  
  if (page && (isNaN(page) || page < 1)) {
    return sendError(res, 400, 'El parámetro page debe ser un número mayor a 0');
  }
  
  if (limit && (isNaN(limit) || limit < 1 || limit > 100)) {
    return sendError(res, 400, 'El parámetro limit debe ser un número entre 1 y 100');
  }
  
  next();
};

// Middleware para sanitizar entrada
const sanitizeInput = (req, res, next) => {
  // Eliminar campos que empiecen con $
  const sanitizeObject = (obj) => {
    for (const key in obj) {
      if (key.startsWith('$')) {
        delete obj[key];
      } else if (typeof obj[key] === 'object' && obj[key] !== null) {
        sanitizeObject(obj[key]);
      }
    }
  };

  if (req.body && typeof req.body === 'object') {
    sanitizeObject(req.body);
  }
  
  if (req.query && typeof req.query === 'object') {
    sanitizeObject(req.query);
  }
  
  next();
};

module.exports = {
  handleValidation,
  validateObjectId,
  validatePagination,
  sanitizeInput
};

