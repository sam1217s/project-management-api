const path = require('path');
const fs = require('fs').promises;
const { sendResponse, sendError } = require('../utils/response.util');

class UploadController {
  // Subir avatar de usuario
  async uploadAvatar(req, res) {
    try {
      if (!req.file) {
        return sendError(res, 400, 'No se seleccionó ningún archivo');
      }

      const { filename, originalname, mimetype, size } = req.file;
      
      // Validar tamaño (5MB máximo)
      if (size > 5 * 1024 * 1024) {
        await this.deleteFile(filename, 'avatars');
        return sendError(res, 400, 'El archivo es demasiado grande (máximo 5MB)');
      }

      const fileUrl = `/uploads/avatars/${filename}`;
      const fullUrl = `${req.protocol}://${req.get('host')}${fileUrl}`;

      sendResponse(res, 200, true, 'Avatar subido exitosamente', {
        file: {
          filename,
          originalname,
          url: fileUrl,
          fullUrl,
          mimetype,
          size: this.formatFileSize(size)
        }
      });
    } catch (error) {
      console.error('Error subir avatar:', error);
      
      // Limpiar archivo si hubo error
      if (req.file) {
        await this.deleteFile(req.file.filename, 'avatars').catch(() => {});
      }
      
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Subir documento
  async uploadDocument(req, res) {
    try {
      if (!req.file) {
        return sendError(res, 400, 'No se seleccionó ningún archivo');
      }

      const { filename, originalname, mimetype, size } = req.file;
      
      // Validar tamaño (10MB máximo para documentos)
      if (size > 10 * 1024 * 1024) {
        await this.deleteFile(filename, 'documents');
        return sendError(res, 400, 'El archivo es demasiado grande (máximo 10MB)');
      }

      const fileUrl = `/uploads/documents/${filename}`;
      const fullUrl = `${req.protocol}://${req.get('host')}${fileUrl}`;

      sendResponse(res, 200, true, 'Documento subido exitosamente', {
        file: {
          filename,
          originalname,
          url: fileUrl,
          fullUrl,
          mimetype,
          size: this.formatFileSize(size),
          uploadedBy: req.user.userId,
          uploadedAt: new Date()
        }
      });
    } catch (error) {
      console.error('Error subir documento:', error);
      
      // Limpiar archivo si hubo error
      if (req.file) {
        await this.deleteFile(req.file.filename, 'documents').catch(() => {});
      }
      
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Eliminar archivo
  async deleteFile(req, res) {
    try {
      const { filename } = req.params;
      const { type = 'documents' } = req.query;

      if (!filename) {
        return sendError(res, 400, 'Nombre de archivo requerido');
      }

      if (!['avatars', 'documents'].includes(type)) {
        return sendError(res, 400, 'Tipo de archivo inválido');
      }

      const deleted = await this.deleteFile(filename, type);
      
      if (!deleted) {
        return sendError(res, 404, 'Archivo no encontrado');
      }

      sendResponse(res, 200, true, 'Archivo eliminado exitosamente');
    } catch (error) {
      console.error('Error eliminar archivo:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Listar archivos
  async listFiles(req, res) {
    try {
      const { type = 'documents' } = req.query;
      const page = parseInt(req.query.page) || 1;
      const limit = parseInt(req.query.limit) || 20;

      if (!['avatars', 'documents'].includes(type)) {
        return sendError(res, 400, 'Tipo de archivo inválido');
      }

      const uploadPath = path.join(__dirname, '../../uploads', type);
      
      try {
        const files = await fs.readdir(uploadPath);
        const fileStats = await Promise.all(
          files.map(async (filename) => {
            const filePath = path.join(uploadPath, filename);
            const stats = await fs.stat(filePath);
            return {
              filename,
              size: this.formatFileSize(stats.size),
              sizeBytes: stats.size,
              created: stats.birthtime,
              modified: stats.mtime,
              url: `/uploads/${type}/${filename}`
            };
          })
        );

        // Ordenar por fecha de creación descendente
        fileStats.sort((a, b) => new Date(b.created) - new Date(a.created));

        // Paginación
        const startIndex = (page - 1) * limit;
        const endIndex = startIndex + limit;
        const paginatedFiles = fileStats.slice(startIndex, endIndex);

        sendResponse(res, 200, true, 'Archivos obtenidos', {
          files: paginatedFiles,
          pagination: {
            page,
            limit,
            total: fileStats.length,
            pages: Math.ceil(fileStats.length / limit)
          }
        });
      } catch (error) {
        if (error.code === 'ENOENT') {
          sendResponse(res, 200, true, 'Carpeta vacía', { files: [], pagination: { page: 1, limit, total: 0, pages: 0 } });
        } else {
          throw error;
        }
      }
    } catch (error) {
      console.error('Error listar archivos:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Método helper para eliminar archivo físico
  async deleteFile(filename, type) {
    try {
      const filePath = path.join(__dirname, '../../uploads', type, filename);
      await fs.access(filePath);
      await fs.unlink(filePath);
      return true;
    } catch (error) {
      if (error.code === 'ENOENT') {
        return false; // Archivo no existe
      }
      throw error;
    }
  }

  // Método helper para formatear tamaño de archivo
  formatFileSize(bytes) {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
  }
}

module.exports = new UploadController();

