// ===================================
const Category = require('../models/Category.model');
const { sendResponse, sendError } = require('../utils/response.util');
const { validationResult } = require('express-validator');

class CategoryController {
  // Listar categorías con filtros y paginación
  async getCategories(req, res) {
    try {
      const page = parseInt(req.query.page) || 1;
      const limit = parseInt(req.query.limit) || 10;
      const search = req.query.search || '';
      const sortBy = req.query.sortBy || 'name';
      const sortOrder = req.query.sortOrder === 'desc' ? -1 : 1;
      const includeInactive = req.query.includeInactive === 'true';
      
      const skip = (page - 1) * limit;

      // Construir filtros
      const filter = {};
      if (!includeInactive) {
        filter.isActive = true;
      }
      if (search) {
        filter.$or = [
          { name: { $regex: search, $options: 'i' } },
          { description: { $regex: search, $options: 'i' } }
        ];
      }

      // Construir ordenamiento
      const sort = {};
      sort[sortBy] = sortOrder;

      const categories = await Category.find(filter)
        .populate('createdBy', 'firstName lastName email')
        .skip(skip)
        .limit(limit)
        .sort(sort);

      const total = await Category.countDocuments(filter);
      const totalActive = await Category.countDocuments({ isActive: true });

      sendResponse(res, 200, true, 'Categorías obtenidas exitosamente', {
        categories,
        pagination: {
          page,
          limit,
          total,
          pages: Math.ceil(total / limit),
          hasNext: page < Math.ceil(total / limit),
          hasPrev: page > 1
        },
        stats: {
          totalActive,
          totalInactive: await Category.countDocuments({ isActive: false })
        }
      });
    } catch (error) {
      console.error('Error obtener categorías:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Obtener categoría por ID
  async getCategoryById(req, res) {
    try {
      const { id } = req.params;
      
      const category = await Category.findById(id)
        .populate('createdBy', 'firstName lastName email')
        .populate('projects', 'name status createdAt');

      if (!category) {
        return sendError(res, 404, 'Categoría no encontrada');
      }

      sendResponse(res, 200, true, 'Categoría obtenida', { category });
    } catch (error) {
      console.error('Error obtener categoría:', error);
      if (error.name === 'CastError') {
        return sendError(res, 400, 'ID de categoría inválido');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Crear nueva categoría
  async createCategory(req, res) {
    try {
      const errors = validationResult(req);
      if (!errors.isEmpty()) {
        return sendError(res, 400, 'Errores de validación', errors.array());
      }

      const { name, description, color, icon } = req.body;

      // Verificar que no exista una categoría con el mismo nombre
      const existingCategory = await Category.findOne({ 
        name: { $regex: new RegExp(`^${name}$`, 'i') } 
      });

      if (existingCategory) {
        return sendError(res, 400, 'Ya existe una categoría con ese nombre');
      }

      const category = await Category.create({
        name: name.trim(),
        description: description.trim(),
        color: color || '#3B82F6',
        icon: icon || 'folder',
        createdBy: req.user.userId
      });

      await category.populate('createdBy', 'firstName lastName email');

      sendResponse(res, 201, true, 'Categoría creada exitosamente', { category });
    } catch (error) {
      console.error('Error crear categoría:', error);
      if (error.code === 11000) {
        return sendError(res, 400, 'Ya existe una categoría con ese nombre');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Actualizar categoría
  async updateCategory(req, res) {
    try {
      const errors = validationResult(req);
      if (!errors.isEmpty()) {
        return sendError(res, 400, 'Errores de validación', errors.array());
      }

      const { id } = req.params;
      const { name, description, color, icon } = req.body;

      const category = await Category.findById(id);
      if (!category) {
        return sendError(res, 404, 'Categoría no encontrada');
      }

      if (!category.isActive) {
        return sendError(res, 400, 'No se puede actualizar una categoría inactiva');
      }

      // Verificar nombre único (excluyendo la categoría actual)
      if (name && name !== category.name) {
        const existingCategory = await Category.findOne({
          name: { $regex: new RegExp(`^${name}$`, 'i') },
          _id: { $ne: id }
        });

        if (existingCategory) {
          return sendError(res, 400, 'Ya existe una categoría con ese nombre');
        }
      }

      // Actualizar campos
      if (name) category.name = name.trim();
      if (description) category.description = description.trim();
      if (color) category.color = color;
      if (icon) category.icon = icon;

      await category.save();
      await category.populate('createdBy', 'firstName lastName email');

      sendResponse(res, 200, true, 'Categoría actualizada exitosamente', { category });
    } catch (error) {
      console.error('Error actualizar categoría:', error);
      if (error.name === 'CastError') {
        return sendError(res, 400, 'ID de categoría inválido');
      }
      if (error.code === 11000) {
        return sendError(res, 400, 'Ya existe una categoría con ese nombre');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Eliminar categoría (soft delete)
  async deleteCategory(req, res) {
    try {
      const { id } = req.params;

      const category = await Category.findById(id);
      if (!category) {
        return sendError(res, 404, 'Categoría no encontrada');
      }

      if (!category.isActive) {
        return sendError(res, 400, 'La categoría ya está inactiva');
      }

      // Verificar si tiene proyectos asociados
      if (category.projectCount > 0) {
        return sendError(res, 400, 'No se puede eliminar una categoría que tiene proyectos asociados');
      }

      category.isActive = false;
      await category.save();

      sendResponse(res, 200, true, 'Categoría eliminada exitosamente');
    } catch (error) {
      console.error('Error eliminar categoría:', error);
      if (error.name === 'CastError') {
        return sendError(res, 400, 'ID de categoría inválido');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Restaurar categoría
  async restoreCategory(req, res) {
    try {
      const { id } = req.params;

      const category = await Category.findById(id);
      if (!category) {
        return sendError(res, 404, 'Categoría no encontrada');
      }

      if (category.isActive) {
        return sendError(res, 400, 'La categoría ya está activa');
      }

      category.isActive = true;
      await category.save();

      sendResponse(res, 200, true, 'Categoría restaurada exitosamente', { category });
    } catch (error) {
      console.error('Error restaurar categoría:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Obtener estadísticas de categorías
  async getCategoryStats(req, res) {
    try {
      const stats = await Category.aggregate([
        {
          $group: {
            _id: null,
            totalCategories: { $sum: 1 },
            activeCategories: { $sum: { $cond: ['$isActive', 1, 0] } },
            inactiveCategories: { $sum: { $cond: ['$isActive', 0, 1] } },
            totalProjects: { $sum: '$projectCount' },
            avgProjectsPerCategory: { $avg: '$projectCount' }
          }
        }
      ]);

      const result = stats[0] || {
        totalCategories: 0,
        activeCategories: 0,
        inactiveCategories: 0,
        totalProjects: 0,
        avgProjectsPerCategory: 0
      };

      // Categorías más usadas
      const topCategories = await Category.find({ isActive: true, projectCount: { $gt: 0 } })
        .sort({ projectCount: -1 })
        .limit(5)
        .select('name projectCount color');

      sendResponse(res, 200, true, 'Estadísticas obtenidas', {
        stats: result,
        topCategories
      });
    } catch (error) {
      console.error('Error obtener estadísticas:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }
}

module.exports = new CategoryController();

