// 9. src/middlewares/error.middleware.js
// ===================================
const { sendError } = require('../utils/response.util');

const errorHandler = (err, req, res, next) => {
  console.error('Error Stack:', err.stack);

  // Error de validación de Mongoose
  if (err.name === 'ValidationError') {
    const errors = Object.values(err.errors).map(error => ({
      field: error.path,
      message: error.message,
      value: error.value
    }));
    return sendError(res, 400, 'Errores de validación', errors);
  }

  // Error de duplicado en MongoDB
  if (err.code === 11000) {
    const field = Object.keys(err.keyPattern)[0];
    const value = err.keyValue[field];
    return sendError(res, 400, `Ya existe un registro con ${field}: ${value}`);
  }

  // Error de casting (ID inválido)
  if (err.name === 'CastError') {
    if (err.path === '_id') {
      return sendError(res, 400, 'ID inválido');
    }
    return sendError(res, 400, `Valor inválido para ${err.path}: ${err.value}`);
  }

  // Error de JWT
  if (err.name === 'JsonWebTokenError') {
    return sendError(res, 401, 'Token inválido');
  }

  if (err.name === 'TokenExpiredError') {
    return sendError(res, 401, 'Token expirado');
  }

  // Error de Multer (archivos)
  if (err.code === 'LIMIT_FILE_SIZE') {
    return sendError(res, 400, 'Archivo demasiado grande');
  }

  if (err.code === 'LIMIT_UNEXPECTED_FILE') {
    return sendError(res, 400, 'Campo de archivo inesperado');
  }

  // Error de conexión a MongoDB
  if (err.name === 'MongoNetworkError') {
    return sendError(res, 503, 'Error de conexión a la base de datos');
  }

  // Errores personalizados
  if (err.isOperational) {
    return sendError(res, err.statusCode || 500, err.message);
  }

  // Error por defecto
  const statusCode = err.statusCode || 500;
  const message = process.env.NODE_ENV === 'production' 
    ? 'Error interno del servidor' 
    : err.message;

  sendError(res, statusCode, message);
};

// Middleware para manejar rutas no encontradas
const notFound = (req, res) => {
  sendError(res, 404, `Ruta ${req.originalUrl} no encontrada`);
};

// Wrapper para funciones async
const asyncHandler = (fn) => (req, res, next) => {
  Promise.resolve(fn(req, res, next)).catch(next);
};

module.exports = {
  errorHandler,
  notFound,
  asyncHandler
};

