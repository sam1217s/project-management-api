const State = require('../models/State.model');
const { sendResponse, sendError } = require('../utils/response.util');
const { validationResult } = require('express-validator');

class StateController {
  // Obtener estados para proyectos
  async getProjectStates(req, res) {
    try {
      const states = await State.getByType('Project');
      
      sendResponse(res, 200, true, 'Estados de proyecto obtenidos', { 
        states,
        count: states.length 
      });
    } catch (error) {
      console.error('Error obtener estados proyecto:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Obtener estados para tareas
  async getTaskStates(req, res) {
    try {
      const states = await State.getByType('Task');
      
      sendResponse(res, 200, true, 'Estados de tarea obtenidos', { 
        states,
        count: states.length 
      });
    } catch (error) {
      console.error('Error obtener estados tarea:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Obtener todos los estados con filtros
  async getAllStates(req, res) {
    try {
      const { type, includeInactive } = req.query;
      
      const filter = {};
      if (type) filter.type = type;
      if (!includeInactive) filter.isActive = true;

      const states = await State.find(filter).sort({ type: 1, order: 1, name: 1 });

      sendResponse(res, 200, true, 'Estados obtenidos', { 
        states,
        count: states.length 
      });
    } catch (error) {
      console.error('Error obtener estados:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Crear nuevo estado (solo Admin)
  async createState(req, res) {
    try {
      const errors = validationResult(req);
      if (!errors.isEmpty()) {
        return sendError(res, 400, 'Errores de validación', errors.array());
      }

      const { name, description, type, color, order } = req.body;

      // Verificar que no exista un estado con el mismo nombre y tipo
      const existingState = await State.findOne({ 
        name: { $regex: new RegExp(`^${name}$`, 'i') },
        type 
      });

      if (existingState) {
        return sendError(res, 400, `Ya existe un estado "${name}" para ${type}`);
      }

      const state = await State.create({
        name: name.trim(),
        description: description ? description.trim() : undefined,
        type,
        color,
        order: order || 0
      });

      sendResponse(res, 201, true, 'Estado creado exitosamente', { state });
    } catch (error) {
      console.error('Error crear estado:', error);
      if (error.code === 11000) {
        return sendError(res, 400, 'Ya existe un estado con ese nombre y tipo');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Actualizar estado (solo Admin)
  async updateState(req, res) {
    try {
      const errors = validationResult(req);
      if (!errors.isEmpty()) {
        return sendError(res, 400, 'Errores de validación', errors.array());
      }

      const { id } = req.params;
      const { name, description, color, order } = req.body;

      const state = await State.findById(id);
      if (!state) {
        return sendError(res, 404, 'Estado no encontrado');
      }

      if (!state.canDelete && req.body.type) {
        return sendError(res, 400, 'No se puede cambiar el tipo de un estado del sistema');
      }

      // Verificar nombre único para el mismo tipo
      if (name && name !== state.name) {
        const existingState = await State.findOne({
          name: { $regex: new RegExp(`^${name}$`, 'i') },
          type: state.type,
          _id: { $ne: id }
        });

        if (existingState) {
          return sendError(res, 400, `Ya existe un estado "${name}" para ${state.type}`);
        }
      }

      // Actualizar campos
      if (name) state.name = name.trim();
      if (description !== undefined) state.description = description ? description.trim() : '';
      if (color) state.color = color;
      if (order !== undefined) state.order = order;

      await state.save();

      sendResponse(res, 200, true, 'Estado actualizado exitosamente', { state });
    } catch (error) {
      console.error('Error actualizar estado:', error);
      if (error.name === 'CastError') {
        return sendError(res, 400, 'ID de estado inválido');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Eliminar estado (solo Admin)
  async deleteState(req, res) {
    try {
      const { id } = req.params;

      const state = await State.findById(id);
      if (!state) {
        return sendError(res, 404, 'Estado no encontrado');
      }

      if (!state.canDelete) {
        return sendError(res, 400, 'Este estado del sistema no se puede eliminar');
      }

      if (state.isDefault) {
        return sendError(res, 400, 'No se puede eliminar el estado por defecto');
      }

      // Verificar si está siendo usado (esto se implementaría cuando existan los modelos Project/Task)
      // const isInUse = await checkIfStateInUse(id, state.type);
      // if (isInUse) {
      //   return sendError(res, 400, 'No se puede eliminar un estado que está siendo usado');
      // }

      state.isActive = false;
      await state.save();

      sendResponse(res, 200, true, 'Estado eliminado exitosamente');
    } catch (error) {
      console.error('Error eliminar estado:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Reordenar estados
  async reorderStates(req, res) {
    try {
      const { states } = req.body; // Array de { id, order }

      if (!Array.isArray(states)) {
        return sendError(res, 400, 'El campo states debe ser un array');
      }

      const updatePromises = states.map(({ id, order }) => 
        State.findByIdAndUpdate(id, { order }, { new: true })
      );

      await Promise.all(updatePromises);

      sendResponse(res, 200, true, 'Estados reordenados exitosamente');
    } catch (error) {
      console.error('Error reordenar estados:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }
}

