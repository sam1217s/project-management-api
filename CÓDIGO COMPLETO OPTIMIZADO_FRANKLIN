    const baseName = path.basename(file.originalname, extension)
      .replace(/[^a-zA-Z0-9]/g, '_')
      .substring(0, 20);
    
    const filename = `${baseName}-${uniqueSuffix}${extension}`;
    cb(null, filename);
  }
