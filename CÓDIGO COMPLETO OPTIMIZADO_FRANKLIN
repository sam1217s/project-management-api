// 4. src/models/State.model.js
// ===================================
const mongoose = require('mongoose');

const stateSchema = new mongoose.Schema({
  name: {
    type: String,
    required: [true, 'El nombre del estado es obligatorio'],
    trim: true,
    minlength: [2, 'El nombre debe tener al menos 2 caracteres'],
    maxlength: [50, 'El nombre no puede exceder 50 caracteres']
  },
  description: {
    type: String,
    trim: true,
    maxlength: [200, 'La descripción no puede exceder 200 caracteres']
  },
  type: {
    type: String,
    required: [true, 'El tipo es obligatorio'],
    enum: {
      values: ['Project', 'Task'],
      message: 'El tipo debe ser Project o Task'
    }
  },
  color: {
    type: String,
    default: function() {
      const colors = {
        'Planificación': '#F59E0B',
        'En Progreso': '#3B82F6', 
        'En Revisión': '#8B5CF6',
        'Completado': '#10B981',
        'Cancelado': '#EF4444',
        'Pendiente': '#6B7280',
        'Bloqueada': '#DC2626'
      };
      return colors[this.name] || '#6B7280';
    },
    match: [/^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$/, 'Debe ser un color hexadecimal válido']
  },
  order: {
    type: Number,
    default: 0,
    min: [0, 'El orden no puede ser negativo']
  },
  isActive: {
    type: Boolean,
    default: true
  },
  isDefault: {
    type: Boolean,
    default: false
  },
  canDelete: {
    type: Boolean,
    default: true
  }
}, {
  timestamps: true
});

// Índice compuesto para evitar duplicados por tipo
stateSchema.index({ name: 1, type: 1 }, { unique: true });
stateSchema.index({ type: 1, order: 1 });
stateSchema.index({ isActive: 1 });

// Método estático para obtener estados por tipo
stateSchema.statics.getByType = function(type) {
  return this.find({ type, isActive: true }).sort({ order: 1, createdAt: 1 });
};

// Método estático para obtener estado por defecto
stateSchema.statics.getDefault = function(type) {
  return this.findOne({ type, isDefault: true, isActive: true });
};

module.exports = mongoose.model('State', stateSchema);

