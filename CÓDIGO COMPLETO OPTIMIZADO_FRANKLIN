const Category = require('../models/Category.model');
const { sendResponse, sendError } = require('../utils/response.util');

class CategoryController {
  // Listar categorías
  async getCategories(req, res) {
    try {
      const page = parseInt(req.query.page) || 1;
      const limit = parseInt(req.query.limit) || 10;
      const skip = (page - 1) * limit;

      const categories = await Category.find({ isActive: true })
        .populate('createdBy', 'firstName lastName')
        .skip(skip)
        .limit(limit)
        .sort({ createdAt: -1 });

      const total = await Category.countDocuments({ isActive: true });

      sendResponse(res, 200, true, 'Categorías obtenidas', {
        categories,
        pagination: {
          page,
          limit,
          total,
          pages: Math.ceil(total / limit)
        }
      });
    } catch (error) {
      console.error('Error categorías:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Crear categoría
  async createCategory(req, res) {
    try {
      const { name, description } = req.body;

      const category = await Category.create({
        name,
        description,
        createdBy: req.user.userId
      });

      await category.populate('createdBy', 'firstName lastName');

      sendResponse(res, 201, true, 'Categoría creada', { category });
    } catch (error) {
      console.error('Error crear categoría:', error);
      if (error.code === 11000) {
        return sendError(res, 400, 'La categoría ya existe');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Actualizar categoría
  async updateCategory(req, res) {
    try {
      const { id } = req.params;
      const { name, description } = req.body;

      const category = await Category.findById(id);
      if (!category || !category.isActive) {
        return sendError(res, 404, 'Categoría no encontrada');
      }

      const updatedCategory = await Category.findByIdAndUpdate(
        id,
        { name, description },
        { new: true, runValidators: true }
      ).populate('createdBy', 'firstName lastName');

      sendResponse(res, 200, true, 'Categoría actualizada', { category: updatedCategory });
    } catch (error) {
      console.error('Error actualizar categoría:', error);
      if (error.code === 11000) {
        return sendError(res, 400, 'El nombre ya existe');
      }
      sendError(res, 500, 'Error interno del servidor');
    }
  }

  // Eliminar categoría
  async deleteCategory(req, res) {
    try {
      const { id } = req.params;

      const category = await Category.findById(id);
      if (!category || !category.isActive) {
        return sendError(res, 404, 'Categoría no encontrada');
      }

      await Category.findByIdAndUpdate(id, { isActive: false });

      sendResponse(res, 200, true, 'Categoría eliminada');
    } catch (error) {
      console.error('Error eliminar categoría:', error);
      sendError(res, 500, 'Error interno del servidor');
    }
  }
}

module.exports = new CategoryController();

